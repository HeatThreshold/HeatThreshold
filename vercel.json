{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build && npx esbuild api-src/handler.ts --bundle --platform=node --format=cjs --target=node20 --packages=external --legal-comments=none --sourcemap --outfile=api/index.js",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "mcp-traces/**",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}

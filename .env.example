# ============================================================================
# Heat Threshold — environment configuration
# ============================================================================
# Copy this file to `.env` (gitignored) and fill in your values. For the
# Vercel deploy, set these under Project Settings → Environment Variables
# instead — see docs/OPERATIONS.md.

# ----------------------------------------------------------------------------
# GEMINI_API_KEY (REQUIRED)
# ----------------------------------------------------------------------------
# Powers the entire Managed Agents pipeline. Without it, POST /api/plan
# returns 500 and the dashboard falls back to demoFixtures.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ----------------------------------------------------------------------------
# GOOGLE_MAPS_PLATFORM_KEY (OPTIONAL — but unlocks the best demo)
# ----------------------------------------------------------------------------
# A single key drives three surfaces at once:
#   1. Maps JavaScript API → live Google Maps embed on the dashboard
#      (fallback: Leaflet/OSM via unpkg)
#   2. Directions API → RouteDirectionsSubAgent polyline + structured steps
#      (fallback: straight-line interpolation between waypoints)
#   3. Map Tiles API → Photorealistic 3D Tiles floor in xr.html
#      (fallback: flat satellite plane)
#
# Lock the key down in the GCP console before deploying:
#   - HTTP referrer restrictions: https://<your-host>/*  and  https://*.vercel.app/*
#   - API restrictions: enable only Maps JavaScript, Directions, and Map Tiles
#   - Daily billing cap (hackathon-friendly)
# See docs/OPERATIONS.md §4 for the full lockdown checklist.
GOOGLE_MAPS_PLATFORM_KEY="MY_GOOGLE_MAPS_PLATFORM_KEY"
